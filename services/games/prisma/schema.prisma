generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoundStatus {
  PENDING
  RUNNING
  CRASHED
}

enum BetStatus {
  PENDING
  CASHED_OUT
}

enum BetProcessingStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model Users {
  id        String   @id @default(uuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bets Bets[]
}

model Rounds {
  id              String      @id @default(uuid())
  status          RoundStatus @default(PENDING)
  crashMultiplier Float?
  startAt         DateTime?
  endedAt         DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  bets Bets[]
}

model Bets {
  id                String    @id @default(uuid())
  userId            String
  roundId           String
  amount            Decimal
  status            BetStatus @default(PENDING)
  processingStatus  BetProcessingStatus @default(PROCESSING)
  cashoutMultiplier Float?
  cashedOutAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  round Rounds @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user  Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roundId])
  @@unique([userId, roundId])
}
